{
  "name": "tariff-refund-request",
  "version": "0.0.0",
  "private": true,
  "description": "IEEPA Refund Audit, Entry Recovery & CAPE Filing-Prep Platform",
  "scripts": {
    "dev": "run-p dev:next dev:inngest",
    "dev:next": "next dev --turbo",
    "dev:inngest": "npx --yes inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "stripe:sync": "tsx scripts/stripe-sync.ts",
    "qa": "npm run lint && npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@axiomhq/js": "^1.6.0",
    "@clerk/nextjs": "^7.2.3",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/nextjs": "^10.49.0",
    "drizzle-orm": "^0.45.2",
    "inngest": "^4.2.4",
    "next": "^15.5.15",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "svix": "^1.91.1"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.17",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
