{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@shared/*": ["./src/shared/*"],
      "@app/*": ["./src/app/*"],
      "server-only": ["./tests/setup/server-only-noop.ts"]
    }
  },
  "include": ["scripts/**/*.ts", "scripts/**/*.tsx", "src/**/*.ts", "src/**/*.tsx"]
}
