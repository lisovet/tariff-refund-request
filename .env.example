# Copy to .env.local and fill in. Never commit .env.local.

# Public origin — canonical URL the app is served from. Used by the
# Clerk sign-in return-URL builder because Railway's internal Node
# hostname (localhost:8080) can't be trusted for redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — Neon (or any Postgres) connection string.
# Get a dev branch URL from the Neon dashboard and paste it here.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Auth — Clerk (lands in task #8). Test keys for dev.
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Storage — Cloudflare R2 (lands in task #3). Use MinIO locally if Docker
# is available; otherwise the in-memory adapter is used.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# R2_BUCKET=

# Workflows — Inngest (lands in task #4).
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Payments — Stripe (lands in task #33). Test keys.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email — Resend (lands in task #27).
# RESEND_API_KEY=

# Observability — Sentry + Axiom (lands in task #5).
# SENTRY_DSN=
# AXIOM_TOKEN=
# AXIOM_DATASET=
